# CATATAN: sekarang API Key, User ID, dan Group ID bisa diisi/diubah
# langsung dari tab "Settings" di website (tersimpan di data/settings.json).
# Isi di bawah ini SIFATNYA OPSIONAL, cuma dipakai sebagai nilai awal/fallback
# kalau kamu belum sempat isi lewat website.

# Ambil dari https://create.roblox.com/dashboard/credentials
# Buat API Key baru -> centang permission "Assets API" -> asset:read + asset:write
ROBLOX_API_KEY=

# User ID Roblox kamu (dari URL profile: roblox.com/users/XXXXXXX/profile)
ROBLOX_USER_ID=

# (Opsional) kalau mau upload sebagai asset Group, isi Group ID
ROBLOX_GROUP_ID=

# Password sederhana biar website upload gak dipakai sembarang orang
UPLOAD_PASSWORD=ganti_dengan_password_kamu

PORT=3000

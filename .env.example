# ============================================================
# Konfigurasi Login dengan Roblox (OAuth2) — GANTIKAN API Key
# ============================================================
# Daftarkan aplikasi OAuth di:
# https://create.roblox.com/dashboard/credentials -> tab "OAuth Apps" -> "Create App"
#
# Saat setup, isi:
#  - Redirect URL: samakan persis dengan ROBLOX_REDIRECT_URI di bawah
#    (contoh lokal: http://localhost:3000/auth/callback)
#  - Scopes yang dicentang minimal: openid, profile,
#    asset:read, asset:write, universe-place:write, group:read

ROBLOX_CLIENT_ID=8643777982360146307
ROBLOX_CLIENT_SECRET=RBX-3Ke_8bZTaE6JsDdi5mqElhQq6WMEOjOTWNfJhPjDDn9LrrnFcLf2gF_B4n3zZfVy
ROBLOX_REDIRECT_URI=https://file-to-model-production.up.railway.app/auth/callback

# String acak panjang buat enkripsi cookie sesi login (WAJIB diganti,
# jangan pakai contoh ini). Bisa generate lewat: openssl rand -hex 32
SESSION_SECRET=ganti-dengan-string-acak-panjang

PORT=3000
